# ── Build outputs ─────────────────────────────────────────────────────────────
*.apk
*.aar
*.aab
*.ap_
*.dex
*.class
bin/
gen/
out/
build/
.gradle/

# ── IDE – IntelliJ / Android Studio ───────────────────────────────────────────
# Ignore the entire .idea folder so IDE-internal files (vcs.xml, etc.)
# never cause merge conflicts or Windows file-lock issues on checkout.
.idea/
*.iml
.idea_modules/
cmake-build-*/

# External native build artefacts
.externalNativeBuild/
.cxx/

# Android Studio captures / profiling
captures/
*.hprof
.navigation/

# ── Credentials & local config ────────────────────────────────────────────────
# Never commit these – each developer has their own
local.properties
google-services.json
*.jks
*.keystore
!debug.keystore

# ── Logs & OS noise ───────────────────────────────────────────────────────────
*.log
proguard/
signingReport/
buck-out/
\.buckd/
.DS_Store
Thumbs.db
*.swp
*.swo

# Reserved Windows device name accidentally created by Gradle
nul
